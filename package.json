{
  "name": "print-bridge",
  "private": true,
  "version": "0.1.3",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "husky",
    "release": "node scripts/release.mjs",
    "release:app": "node scripts/release.mjs app",
    "verify:config-transfer-examples": "node scripts/verify-config-transfer-examples.mjs",
    "lint": "oxlint src vite.config.ts",
    "lint:fix": "oxlint --fix src vite.config.ts",
    "format": "oxfmt --write \"src/**/*\" vite.config.ts tsconfig.json tsconfig.node.json",
    "format:check": "oxfmt --check \"src/**/*\" vite.config.ts tsconfig.json tsconfig.node.json",
    "lint-staged": "lint-staged",
    "typecheck": "vue-tsc --noEmit",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@tanstack/vue-table": "^8.21.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,vue}": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ],
    "*.css": "oxfmt --write --no-error-on-unmatched-pattern"
  }
}
