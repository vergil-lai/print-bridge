{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrintBridge",
  "version": "0.1.0",
  "identifier": "com.vergil.printbridge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PrintBridge",
        "width": 960,
        "height": 680,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/windows/SumatraPDF.exe": "SumatraPDF.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1NDcxN0M3NzBFMzY3NEYKUldSUForTnd4eGRIbGZvV3dqSUdlU3kzR1hRRytPZlpHcUZLZGdOanpsZWZjM0UvK3BtelZ6WGwK",
      "endpoints": [
        "https://github.com/vergil-lai/print-bridge/releases/latest/download/latest.json"
      ]
    }
  }
}
